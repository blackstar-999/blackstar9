APP_NAME="School Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Tashkent

# Hidden SuperAdmin login path (change this in production!)
